# Copy to: /home/ubuntu/apps/workspace-rag-assistant/apps/api/.env
# Do not commit the real .env file.

NODE_ENV=production
PORT=4100

# Local EC2 Postgres. Replace password and keep host on localhost.
DATABASE_URL=postgresql://workspace_rag_app:replace-with-db-password@127.0.0.1:5432/workspace_rag?schema=public

# Public HTTPS origin served by Nginx/Certbot.
WEB_ORIGIN=https://workspace-rag.example.com
API_ORIGIN=https://workspace-rag.example.com

# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-long-jwt-secret
COOKIE_SECRET=replace-with-long-cookie-secret

AI_PROVIDER=gemini
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_CHAT_MODEL=gemini-3.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIMENSIONS=1536

MAX_UPLOAD_BYTES=5242880
