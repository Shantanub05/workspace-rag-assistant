# Copy to: /home/ubuntu/config/workspace-rag/web/.env.production
# Symlink to: /home/ubuntu/apps/workspace-rag-assistant/apps/web/.env.production
# Do not commit the real env file.

NEXT_PUBLIC_APP_NAME=Workspace RAG Assistant

# On EC2, Nginx sends browser /api/* requests directly to the API.
# This value is still used by Next.js rewrites when a request reaches the web server.
API_INTERNAL_ORIGIN=http://127.0.0.1:4100
